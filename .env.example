# ─────────────────────────────────────────────────────────────────────────────
# Marketplace Golden Bears — variables de entorno
# Copia este archivo a `.env` y completa lo necesario.
# ─────────────────────────────────────────────────────────────────────────────

# SUPABASE (persistencia real — productos, carrito, órdenes, inventario)
# Crea un proyecto gratis en https://supabase.com y pega tus credenciales.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# MODO DEMO vs PRODUCCIÓN
# demo (default)      → agentes usan heurística mock (sin costo, sin API key).
# production           → agentes llaman a Groq (Llama 3.1 8B) / Gemini 1.5 Flash vía proxy serverless.
VITE_MODE=demo

# PROXY LLM (recomendado para producción)
# Con VITE_USE_PROXY=true el front NO llama a Groq/Gemini directo: pasa por
# /api/llm, que vive en el servidor y usa GROQ_API_KEY / GEMINI_API_KEY (sin
# prefijo VITE_, así nunca se incrustan en el bundle del navegador).
# GROQ_API_KEY   → Orquestador y ResolutionAgent (Llama 3.1 8B, clasificación rápida/económica).
# GEMINI_API_KEY → ConciergeAgent/SearchAgent (Gemini 1.5 Flash, RAG/búsqueda semántica).
VITE_USE_PROXY=false
GROQ_API_KEY=
GEMINI_API_KEY=

# Dominios extra permitidos por el proxy (separados por coma), además del propio host.
ALLOWED_ORIGINS=

# VALIDACIÓN JWT (opcional — ver api/_guard.js)
# Este proyecto no tiene login de usuarios; el JWT verificado es el propio
# anon key de Supabase (ya público en el bundle). Si se configura, los
# proxies exigen un header "Authorization: Bearer <anon key>" con firma
# HS256 válida. JWT Secret está en tu proyecto Supabase → Settings → API.
SUPABASE_JWT_SECRET=

# OBSERVABILIDAD CON LANGSMITH (opcional)
# Si LANGSMITH_TRACING no es "true" o falta la API key, /api/trace responde
# { disabled: true } sin error — la trazabilidad nunca bloquea el flujo
# transaccional del sistema multiagente. Registra las llamadas a Groq/Gemini
# y las alertas HITL del ResolutionAgent (confianza < 0.8).
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=marketplace-goldenbears-sma

# NOTIFICACIONES POR EMAIL (opcional — Gmail SMTP, igual que el backend Python original)
# Si se deja vacío, el sistema simula el envío sin fallar (ver agents/notificaciones.py).
GMAIL_USER=
GMAIL_APP_PASSWORD=
SELLER_EMAIL=

