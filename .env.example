# ─────────────────────────────────────────────────────────────────────────────
# Marketplace Golden Bears — variables de entorno
# Copia este archivo a `.env` y completa lo necesario.
# ─────────────────────────────────────────────────────────────────────────────

# SUPABASE (persistencia real — productos, carrito, órdenes, inventario)
# Crea un proyecto gratis en https://supabase.com y pega tus credenciales.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# MODO DEMO vs PRODUCCIÓN
# demo (default)      → agentes usan heurística mock (sin costo, sin API key).
# production           → agentes llaman a Claude Haiku vía proxy serverless.
VITE_MODE=demo

# PROXY LLM (recomendado para producción)
# Con VITE_USE_PROXY=true el front NO llama a Anthropic directo: pasa por
# /api/llm, que vive en el servidor y usa ANTHROPIC_API_KEY (sin prefijo VITE_,
# así nunca se incrusta en el bundle del navegador).
VITE_USE_PROXY=false
ANTHROPIC_API_KEY=

# Dominios extra permitidos por el proxy (separados por coma), además del propio host.
ALLOWED_ORIGINS=

# NOTIFICACIONES POR EMAIL (opcional — Gmail SMTP, igual que el backend Python original)
# Si se deja vacío, el sistema simula el envío sin fallar (ver agents/notificaciones.py).
GMAIL_USER=
GMAIL_APP_PASSWORD=
SELLER_EMAIL=

